{
  "name": "@tw-masonry/vue",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tw-masonry/core": "workspace:*",
    "@tw-masonry/dom": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  }
}
